{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/assets/*",
      "/icons/*",
      "/canvaskit/*",
      "/*.{js,wasm,json,png,ico,svg,xml,txt,ttf,otf,woff,woff2}"
    ]
  },
  "mimeTypes": {
    ".wasm": "application/wasm",
    ".js": "text/javascript",
    ".json": "application/json"
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html"
    }
  }
}
